# ============================================================
# 环境变量 (请勿提交到 Git)
# 复制此文件为 .env 并填入真实值
# ============================================================

# VLM API 密钥 (通义千问 / Qwen-VL)
DASHSCOPE_API_KEY=your_api_key_here

# 可选：其他 VLM 提供商
QWEN_VL_API_KEY=
OPENAI_API_KEY=

# 数据库加密密钥 (可选)
DB_ENCRYPT_KEY=

# Gradio 认证 (可选，格式: user:pass)
GRADIO_AUTH=
